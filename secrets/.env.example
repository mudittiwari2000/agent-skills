# agent-skills secrets template — KEY NAMES ONLY, never commit values.
# Real values live in ~/.config/agent-secrets/.env (chmod 600).
# Run `bash install.sh --bootstrap-secrets` to create/fill it from the
# Pegasus profile (~/.hermes/profiles/pegasus/.env).

# --- Atlassian (Jira Cloud + Confluence Cloud share one API token) ---
PEI_JIRA_USER_EMAIL=
PEI_JIRA_API_TOKEN=
PEI_JIRA_BASE_URL=
PEI_JIRA_PROJECT_KEY=
PEI_JIRA_SWARM_USER_EMAIL=
PEI_JIRA_STORY_POINTS_FIELD=

# Optional Confluence-specific overrides; when empty, skills fall back to
# the PEI_JIRA_* values above (verified to work against /wiki).
PEI_CONFLUENCE_BASE_URL=
PEI_CONFLUENCE_USER_EMAIL=
PEI_CONFLUENCE_API_TOKEN=

# --- GitLab ---
GITLAB_HOST=
GITLAB_TOKEN=
GITLAB_PERSONAL_ACCESS_TOKEN=

# --- Figma ---
FIGMA_API_KEY=

# --- Datadog ---
DD_API_KEY=
DD_APP_KEY=
DD_SITE=

# --- Databricks ---
PEI_DATABRICKS_PROFILE=
